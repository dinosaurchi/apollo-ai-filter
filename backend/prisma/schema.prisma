generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  companyId                                String   @id @map("company_id") @db.Text
  companyName                              String   @default("") @map("company_name") @db.Text
  companyDomain                            String   @default("") @map("company_domain") @db.Text
  companyNameForEmails                     String   @default("") @map("company_name_for_emails") @db.Text
  employees                                String   @default("") @db.Text
  industry                                 String   @default("") @db.Text
  website                                  String   @default("") @db.Text
  companyLinkedinUrl                       String   @default("") @map("company_linkedin_url") @db.Text
  facebookUrl                              String   @default("") @map("facebook_url") @db.Text
  twitterUrl                               String   @default("") @map("twitter_url") @db.Text
  companyCity                              String   @default("") @map("company_city") @db.Text
  companyState                             String   @default("") @map("company_state") @db.Text
  companyCountry                           String   @default("") @map("company_country") @db.Text
  keywords                                 String   @default("") @db.Text
  companyPhone                             String   @default("") @map("company_phone") @db.Text
  totalFunding                             String   @default("") @map("total_funding") @db.Text
  latestFunding                            String   @default("") @map("latest_funding") @db.Text
  latestFundingAmount                      String   @default("") @map("latest_funding_amount") @db.Text
  lastRaisedAt                             String   @default("") @map("last_raised_at") @db.Text
  annualRevenue                            String   @default("") @map("annual_revenue") @db.Text
  apolloAccountId                          String   @default("") @map("apollo_account_id") @db.Text
  sicCodes                                 String   @default("") @map("sic_codes") @db.Text
  naicsCodes                               String   @default("") @map("naics_codes") @db.Text
  shortDescription                         String   @default("") @map("short_description") @db.Text
  foundedYear                              String   @default("") @map("founded_year") @db.Text
  subsidiaryOf                             String   @default("") @map("subsidiary_of") @db.Text
  stablecoinProspect9854                   String   @default("") @map("stablecoin_prospect_9854") @db.Text
  qualifyAccount                           String   @default("") @map("qualify_account") @db.Text
  prerequisiteDetermineResearchGuidelines  String   @default("") @map("prerequisite_determine_research_guidelines") @db.Text
  prerequisiteResearchTargetCompany        String   @default("") @map("prerequisite_research_target_company") @db.Text
  sourceRunId                              String   @default("") @map("source_run_id") @db.Text
  createdAt                                DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                                DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("companies")
}

model Person {
  personId     String   @id @map("person_id") @db.Text
  companyId    String   @default("") @map("company_id") @db.Text
  fullName     String   @default("") @map("full_name") @db.Text
  title        String   @default("") @db.Text
  email        String   @default("") @db.Text
  linkedinUrl  String   @default("") @map("linkedin_url") @db.Text
  location     String   @default("") @db.Text
  sourceRunId  String   @default("") @map("source_run_id") @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([companyId], map: "idx_people_company_id")
  @@map("people")
}

model ReviewCompany {
  id          String    @id @db.Text
  companyId   String    @map("company_id") @db.Text
  fieldName   String    @map("field_name") @db.Text
  oldValue    String    @default("") @map("old_value") @db.Text
  newValue    String    @default("") @map("new_value") @db.Text
  sourceRunId String    @default("") @map("source_run_id") @db.Text
  status      String    @default("pending") @db.Text
  resolution  String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  resolvedAt  DateTime? @map("resolved_at") @db.Timestamptz(6)

  @@index([status, createdAt(sort: Desc)], map: "idx_review_company_pending")
  @@map("review_company")
}

model ReviewPeople {
  id          String    @id @db.Text
  personId    String    @map("person_id") @db.Text
  fieldName   String    @map("field_name") @db.Text
  oldValue    String    @default("") @map("old_value") @db.Text
  newValue    String    @default("") @map("new_value") @db.Text
  sourceRunId String    @default("") @map("source_run_id") @db.Text
  status      String    @default("pending") @db.Text
  resolution  String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  resolvedAt  DateTime? @map("resolved_at") @db.Timestamptz(6)

  @@index([status, createdAt(sort: Desc)], map: "idx_review_people_pending")
  @@map("review_people")
}

model RunIngestion {
  runId             String    @id @map("run_id") @db.Text
  status            String    @default("pending") @db.Text
  attemptCount      Int       @default(0) @map("attempt_count")
  lastError         String    @default("") @map("last_error") @db.Text
  lastAttemptAt     DateTime? @map("last_attempt_at") @db.Timestamptz(6)
  completedAt       DateTime? @map("completed_at") @db.Timestamptz(6)
  companyRowsWritten Int      @default(0) @map("company_rows_written")
  peopleRowsWritten Int       @default(0) @map("people_rows_written")
  companiesIngested Boolean   @default(false) @map("companies_ingested")
  peopleIngested    Boolean   @default(false) @map("people_ingested")
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([status, updatedAt(sort: Desc)], map: "idx_run_ingestion_status")
  @@map("run_ingestion")
}
