{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "people.query.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "page": {
      "type": "integer",
      "minimum": 1
    },
    "per_page": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    },
    "organization_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "q_organization_domains_list": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "person_titles": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "person_seniorities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["ic", "manager", "director", "vp", "c_suite", "head"]
      }
    },
    "person_locations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "q_keywords": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
